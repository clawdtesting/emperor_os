{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "emperor-os/agent-job-result.schema.json",
  "title": "External Agent Job Result",
  "type": "object",
  "required": ["schema", "jobId", "status", "summary", "deliverables", "evidence", "warnings"],
  "properties": {
    "schema": { "const": "emperor-os/agent-job-result/v1" },
    "jobId": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "sha256": { "type": "string" },
          "mimeType": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "evidence": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "toolTrace": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "agentMeta": { "type": "object", "additionalProperties": true },
    "metrics": { "type": "object", "additionalProperties": true },
    "proposedCompletion": { "type": "object", "additionalProperties": true },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
