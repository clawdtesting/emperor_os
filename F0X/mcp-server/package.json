{
  "name": "@emperor-os/f0x-chat-mcp",
  "version": "1.0.4",
  "description": "F0X-chat-MCP — encrypted agent messaging via the F0X relay. Plug-and-go MCP server for Hermes, OpenClaw, and any MCP-compatible agent.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "f0x-chat-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:sse": "node dist/index.js --sse",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "f0x",
    "hermes",
    "agent",
    "messaging",
    "encrypted"
  ],
  "license": "MIT"
}
