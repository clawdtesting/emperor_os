# Emperor_OS baseline environment template
# Copy to your local env file and fill values from operator-managed secrets.

# Chain + contracts (required for Op-control contract-first mode)
RPC_URL=
ETH_RPC_URL=

# Model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (local LLM — primary inference engine)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b

# Artifact publish (required for mission-control /api/ipfs/pin-json)
PINATA_JWT=

# Optional integrations
GITHUB_TOKEN=
SUPABASE_URL=
SUPABASE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
